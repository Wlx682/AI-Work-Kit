{
  "_comment": "复制为 mcp.json 后去掉 _comment 字段。项目级：.cursor/mcp.json；全局：~/.cursor/mcp.json",
  "mcpServers": {
    "enquire": {
      "command": "npx",
      "args": [
        "-y",
        "@oomkapwn/enquire-mcp@latest",
        "serve",
        "--vault",
        "/path/to/AI-Work-Kit",
        "--persistent-index"
      ]
    }
  }
}
